# =============================================================================
# RETINA - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in appropriate values.
# DO NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Connection URL for Redis (used by both backend and worker)
REDIS_URL=redis://localhost:6379

# Redis key prefix for namespacing (useful for multi-tenant or testing)
REDIS_KEY_PREFIX=retina:

# -----------------------------------------------------------------------------
# Backend (Rust/Axum) Configuration
# -----------------------------------------------------------------------------
# Server binding address and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Logging level: trace, debug, info, warn, error
RUST_LOG=info,tower_http=debug

# CORS allowed origins (comma-separated for multiple)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# ML Worker (Python) Configuration
# -----------------------------------------------------------------------------
# Number of worker processes (for scaling inference)
WORKER_CONCURRENCY=2

# Default model for unsupervised detection
# Options: patchcore, padim, winclip (stubs in current implementation)
DEFAULT_UNSUPERVISED_MODEL=patchcore

# Batch size for inference (when batch processing is implemented)
INFERENCE_BATCH_SIZE=8

# Model weights directory (relative to worker/)
MODEL_WEIGHTS_DIR=./models/weights

# -----------------------------------------------------------------------------
# Frontend (Next.js) Configuration
# -----------------------------------------------------------------------------
# Public API URL (accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Active Learning Configuration
# -----------------------------------------------------------------------------
# Minimum labeled samples required to activate Stage 2 (supervised learning)
AL_STAGE2_THRESHOLD=100

# Uncertainty sampling strategy: entropy, margin, least_confidence
AL_SAMPLING_STRATEGY=entropy

# Pool size for active learning candidates
AL_POOL_SIZE=50

# -----------------------------------------------------------------------------
# Development / Debug
# -----------------------------------------------------------------------------
# Enable debug mode (additional logging, mock delays)
DEBUG_MODE=true

# Simulated inference delay in milliseconds (for testing UI responsiveness)
MOCK_INFERENCE_DELAY_MS=500
