# RETINA — Environment Variables Template
# Copy this file to .env and fill in real values. Never commit .env.

# =============================================================================
# Database
# =============================================================================
POSTGRES_PASSWORD=change_me_strong_password

# =============================================================================
# Security
# =============================================================================
# Must be at least 32 random characters in production
JWT_SECRET=change_me_at_least_32_chars_random_string

# =============================================================================
# OpenAI (required for GPT-4o zero-shot Stage 1 fallback)
# =============================================================================
OPENAI_API_KEY=sk-...

# =============================================================================
# Worker ML Configuration
# =============================================================================
PATCHCORE_CHECKPOINT_PATH=/data/checkpoints/patchcore.pt
GPT4V_PRODUCT_TYPE=manufactured product

# =============================================================================
# Connection Strings
# =============================================================================
DATABASE_URL=postgresql://retina:${POSTGRES_PASSWORD}@postgres:5432/retina
REDIS_URL=redis://redis:6379

# =============================================================================
# Frontend
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
